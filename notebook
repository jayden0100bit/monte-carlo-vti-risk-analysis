# Dark, professional colour palette
_BG_DARK  = "#0d1117"
_BG_PANEL = "#161b22"
_BORDER   = "#30363d"
_TEXT_LO  = "#8b949e"
_TEXT_HI  = "#e6edf3"
_TEXT_MID = "#c9d1d9"
