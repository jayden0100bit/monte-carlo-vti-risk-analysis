# ──────────────────────────────────────────────────────────────────────────────
#  Configuration
# ──────────────────────────────────────────────────────────────────────────────

TICKER          = "VTI"          # Vanguard Total Stock Market ETF
INITIAL_VALUE   = 10_000         # Starting portfolio value (USD)
TIME_HORIZON    = 252            # Trading days to simulate (252 ≈ 1 year)
NUM_SIMULATIONS = 10_000         # Monte Carlo paths
LOOKBACK_YEARS  = 5              # Years of historical data to use for calibration
RANDOM_SEED     = 42             # For reproducibility


# ──────────────────────────────────────────────────────────────────────────────
#  1. Data Collection
# ──────────────────────────────────────────────────────────────────────────────

def get_data(
    ticker: str = TICKER,
    lookback_years: int = LOOKBACK_YEARS,
) -> pd.Series:
    """
    Download adjusted closing prices from Yahoo Finance via yfinance.

    Falls back to a synthetic dataset (calibrated to VTI's historical
    characteristics) when network access is unavailable, so the project
    runs end-to-end in restricted environments.

    Parameters
    ----------
    ticker        : str  – Yahoo Finance ticker symbol (default "VTI")
    lookback_years: int  – Years of history to pull (default 5)

    Returns
    -------
    pd.Series  – Daily adjusted closing prices indexed by date.
    """
    end_date   = datetime.today()
    start_date = end_date - timedelta(days=lookback_years * 365)

    try:
        import yfinance as yf

        print(f"  ⬇  Downloading {ticker} data ({start_date.date()} → {end_date.date()}) …")
        raw = yf.download(
            ticker,
            start=start_date.strftime("%Y-%m-%d"),
            end=end_date.strftime("%Y-%m-%d"),
            auto_adjust=True,
            progress=False,
        )

        if raw.empty:
            raise ValueError("yfinance returned an empty DataFrame.")

        # Handle multi-level columns that newer yfinance versions produce
        if isinstance(raw.columns, pd.MultiIndex):
            raw.columns = raw.columns.get_level_values(0)

        prices = raw["Close"].dropna()

        if len(prices) < 60:
            raise ValueError(f"Insufficient data: only {len(prices)} rows returned.")

        print(f"  ✅  Downloaded {len(prices)} trading days of {ticker} data.\n")
        return prices

    except Exception as exc:
        print(f"  ⚠️   Could not fetch live data ({exc}).")
        print(f"  ↩   Using synthetic VTI-calibrated data for demonstration.\n")
        return _generate_synthetic_vti(lookback_years)


def _generate_synthetic_vti(lookback_years: int) -> pd.Series:
    """
    Generate synthetic price series calibrated to VTI's historical parameters.
    Used as a graceful fallback when yfinance cannot reach the network.

    VTI historical reference (2019-2024):
        Annual return  ≈ 14%  →  daily mu  ≈ 0.00055
        Annual vol     ≈ 18%  →  daily sigma ≈ 0.0113
    """
    rng        = np.random.default_rng(RANDOM_SEED)
    n_days     = lookback_years * 252
    mu_daily   = 0.00055
    sig_daily  = 0.0113

    log_returns = rng.normal(
        loc   = mu_daily - 0.5 * sig_daily ** 2,
        scale = sig_daily,
        size  = n_days,
    )
    price_series = 200.0 * np.exp(np.cumsum(log_returns))   # start ≈ $200 (2019 VTI level)

    end_date   = datetime.today()
    start_date = end_date - timedelta(days=n_days * 1.4)    # account for weekends
    dates      = pd.bdate_range(end=end_date, periods=n_days)

    return pd.Series(price_series, index=dates, name="Close (synthetic VTI)")


# ──────────────────────────────────────────────────────────────────────────────
#  2. Return Calculation & Parameter Estimation
# ──────────────────────────────────────────────────────────────────────────────

@dataclass
class ReturnStats:
    """Descriptive statistics estimated from historical returns."""
    mu_daily:    float          # Mean daily return
    sigma_daily: float          # Std-dev of daily returns
    mu_annual:   float          # Annualised return (×252)
    sigma_annual: float         # Annualised volatility (×√252)
    total_return: float         # Cumulative return over the sample window
    sharpe_approx: float        # Approx. Sharpe ratio (risk-free = 0)
    n_obs:        int           # Number of return observations
    prices:       pd.Series = field(repr=False)
    returns:      pd.Series = field(repr=False)


def calculate_returns(prices: pd.Series) -> ReturnStats:
    """
    Compute daily log-returns and estimate statistical parameters.

    Using log-returns (ln(P_t / P_{t-1})) rather than simple percentage
    changes because they are additive across time and better suited to
    the normal-distribution assumption.

    Parameters
    ----------
    prices : pd.Series  – Adjusted closing price series.

    Returns
    -------
    ReturnStats  – Estimated parameters and descriptive statistics.
    """
    log_returns = np.log(prices / prices.shift(1)).dropna()

    mu_daily    = float(log_returns.mean())
    sigma_daily = float(log_returns.std())
    mu_annual   = mu_daily * 252
    sigma_annual = sigma_daily * np.sqrt(252)

    total_return = float((prices.iloc[-1] / prices.iloc[0]) - 1)
    sharpe_approx = mu_annual / sigma_annual if sigma_annual > 0 else 0.0

    print("  📐  Historical Parameter Estimates")
    print(f"      Daily μ  (mean log-return) : {mu_daily:.6f}")
    print(f"      Daily σ  (volatility)      : {sigma_daily:.6f}")
    print(f"      Annual μ                   : {mu_annual * 100:.2f}%")
    print(f"      Annual σ                   : {sigma_annual * 100:.2f}%")
    print(f"      Total return ({len(log_returns)} days)  : {total_return * 100:.1f}%")
    print(f"      Approx. Sharpe ratio       : {sharpe_approx:.2f}\n")

    return ReturnStats(
        mu_daily     = mu_daily,
        sigma_daily  = sigma_daily,
        mu_annual    = mu_annual,
        sigma_annual = sigma_annual,
        total_return = total_return,
        sharpe_approx = sharpe_approx,
        n_obs        = len(log_returns),
        prices       = prices,
        returns      = log_returns,
    )


# ──────────────────────────────────────────────────────────────────────────────
#  3. Monte Carlo Simulation
# ──────────────────────────────────────────────────────────────────────────────

def simulate_portfolio(
    stats: ReturnStats,
    initial_value: float = INITIAL_VALUE,
    time_horizon:  int   = TIME_HORIZON,
    num_sims:      int   = NUM_SIMULATIONS,
    seed:          int   = RANDOM_SEED,
) -> np.ndarray:
    """
    Simulate portfolio value paths using Geometric Brownian Motion.

    Each path follows:
        V(t+1) = V(t) × exp(r_t)
        r_t ~ N(μ - 0.5σ², σ²)

    The Itô correction (−0.5σ²) ensures the expected portfolio value
    equals S₀ × exp(μT), keeping the simulation unbiased.

    Parameters
    ----------
    stats         : ReturnStats  – Calibrated parameters from historical data.
    initial_value : float        – Starting portfolio value in USD.
    time_horizon  : int          – Number of trading days to project.
    num_sims      : int          – Number of independent paths to generate.
    seed          : int          – Random seed for reproducibility.

    Returns
    -------
    np.ndarray, shape (time_horizon + 1, num_sims)
        Portfolio value at every time step across all simulated paths.
    """
    rng   = np.random.default_rng(seed)
    drift = stats.mu_daily - 0.5 * stats.sigma_daily ** 2

    # Draw ALL random shocks at once — fully vectorised, no Python loops
    shocks = rng.normal(
        loc   = drift,
        scale = stats.sigma_daily,
        size  = (time_horizon, num_sims),
    )

    # Convert daily log-returns to cumulative price paths
    log_paths = np.vstack([np.zeros((1, num_sims)), np.cumsum(shocks, axis=0)])
    paths     = initial_value * np.exp(log_paths)   # shape: (T+1, N)

    print(f"  🎲  Simulation complete: {num_sims:,} paths × {time_horizon} days generated.\n")
    return paths


# ──────────────────────────────────────────────────────────────────────────────
#  4. Risk Metrics
# ──────────────────────────────────────────────────────────────────────────────

@dataclass
class RiskMetrics:
    """All computed portfolio risk and return metrics."""
    initial_value:  float
    expected_value: float
    median_value:   float
    std_deviation:  float
    min_value:      float
    max_value:      float
    prob_of_loss:   float   # Fraction of paths ending below initial investment
    var_95:         float   # Value at Risk — 5th percentile of final distribution
    cvar_95:        float   # Conditional VaR — mean of worst 5% outcomes
    expected_gain:  float   # Expected P&L in dollar terms
    expected_gain_pct: float


def calculate_metrics(
    paths:         np.ndarray,
    initial_value: float,
) -> RiskMetrics:
    """
    Derive risk metrics from the final portfolio values across all simulations.

    Parameters
    ----------
    paths         : np.ndarray – Simulation output, shape (T+1, N).
    initial_value : float      – Starting portfolio value.

    Returns
    -------
    RiskMetrics  – Fully populated risk metrics dataclass.
    """
    final = paths[-1, :]

    var_95       = float(np.percentile(final, 5))
    tail_losses  = final[final <= var_95]
    cvar_95      = float(tail_losses.mean()) if len(tail_losses) > 0 else var_95

    exp_val    = float(final.mean())
    exp_gain   = exp_val - initial_value
    exp_gain_pct = (exp_gain / initial_value) * 100

    return RiskMetrics(
        initial_value    = initial_value,
        expected_value   = exp_val,
        median_value     = float(np.median(final)),
        std_deviation    = float(final.std()),
        min_value        = float(final.min()),
        max_value        = float(final.max()),
        prob_of_loss     = float(np.mean(final < initial_value)),
        var_95           = var_95,
        cvar_95          = cvar_95,
        expected_gain    = exp_gain,
        expected_gain_pct = exp_gain_pct,
    )


def print_metrics(metrics: RiskMetrics, num_sims: int, time_horizon: int) -> None:
    """Pretty-print the risk report to stdout."""
    bar = "═" * 54
    sign = "+" if metrics.expected_gain >= 0 else ""

    print(f"\n{bar}")
    print(f"  📊  Monte Carlo Risk Report — VTI Portfolio")
    print(bar)
    print(f"  Simulations      : {num_sims:>12,}")
    print(f"  Time Horizon     : {time_horizon:>9} trading days")
    print(f"  Initial Value    : ${metrics.initial_value:>12,.2f}")
    print(bar)
    print(f"  Expected Value   : ${metrics.expected_value:>12,.2f}")
    print(f"  Median Value     : ${metrics.median_value:>12,.2f}")
    print(f"  Std Deviation    : ${metrics.std_deviation:>12,.2f}")
    print(f"  Best Case        : ${metrics.max_value:>12,.2f}")
    print(f"  Worst Case       : ${metrics.min_value:>12,.2f}")
    print(bar)
    print(f"  Expected P&L     : {sign}${metrics.expected_gain:>11,.2f}  "
          f"({sign}{metrics.expected_gain_pct:.1f}%)")
    print(f"  Probability Loss : {metrics.prob_of_loss * 100:>11.2f}%")
    print(f"  VaR  (95% conf.) : ${metrics.var_95:>12,.2f}")
    print(f"  CVaR (95% conf.) : ${metrics.cvar_95:>12,.2f}")
    loss_at_var = metrics.initial_value - metrics.var_95
    print(f"  Max Loss @ VaR   : ${loss_at_var:>12,.2f}")
    print(f"{bar}\n")


