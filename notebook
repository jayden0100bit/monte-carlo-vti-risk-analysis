            vc = _GREEN
        elif is_good is False and ridx > 0:
            vc = _RED if "Loss" in label or "Probability" in label else _TEXT_MID
        else:
            vc = _RED if ("Loss" in label or "Probability" in label or
                          "VaR" in label or "CVaR" in label) else _TEXT_MID

        if is_hdr:
            ax_card.plot([0.02, 0.98], [y - 0.015, y - 0.015],
                         color=_BORDER, lw=0.8, transform=ax_card.transAxes)

        ax_card.text(xl, y, label, transform=ax_card.transAxes,
                     fontsize=8.2, fontweight=fw, color=lc, va="top")
        ax_card.text(xr, y, value, transform=ax_card.transAxes,
                     fontsize=8.2, fontweight=fw, color=vc, va="top",
                     fontfamily="monospace")

    # ── Panel C: Simulation Paths (bottom-left, spans 2 cols) ────────────
    ax_paths = fig.add_subplot(gs[1, :2])
    days = np.arange(time_horizon + 1)
    N    = paths.shape[1]

    sample_idx = np.random.default_rng(1).choice(N, size=min(80, N), replace=False)
    for i in sample_idx:
        ax_paths.plot(days, paths[:, i], lw=0.35, alpha=0.2, color=_BLUE)

    p5  = np.percentile(paths, 5,  axis=1)
    p50 = np.percentile(paths, 50, axis=1)
    p95 = np.percentile(paths, 95, axis=1)

    ax_paths.fill_between(days, p5, p95, alpha=0.10, color=_BLUE)
    ax_paths.plot(days, p5,  color=_RED,    lw=1.6, ls="--", label=f"5th Pct — ${p5[-1]:,.0f}")
    ax_paths.plot(days, p50, color=_GREEN,  lw=2.0,          label=f"Median — ${p50[-1]:,.0f}")
    ax_paths.plot(days, p95, color=_YELLOW, lw=1.6, ls="--", label=f"95th Pct — ${p95[-1]:,.0f}")
    ax_paths.axhline(metrics.initial_value, color=_TEXT_LO, lw=1.2, ls=":",
                     label=f"Initial — ${metrics.initial_value:,.0f}")
    ax_paths.set_title(f"{num_sims:,} Simulated Paths × {time_horizon} Days", fontsize=10.5, fontweight="bold")
    ax_paths.set_xlabel("Trading Days Ahead", fontsize=9)
    ax_paths.set_ylabel("Portfolio Value (USD)", fontsize=9)
    _fmt_usd(ax_paths)
    ax_paths.legend(ncol=2, fontsize=7.5)
    ax_paths.grid(True, alpha=0.28)

    # ── Panel D: Histogram (bottom-right) ────────────────────────────────
    ax_h = fig.add_subplot(gs[1, 2])
    final = paths[-1, :]
    n_bins = min(80, int(np.sqrt(len(final))))
    counts, edges = np.histogram(final, bins=n_bins)

    for i, (lo, hi) in enumerate(zip(edges[:-1], edges[1:])):
        color = _RED if (lo + hi) / 2 < metrics.initial_value else _GREEN
        ax_h.bar(lo, counts[i], width=(hi - lo), color=color, alpha=0.72, edgecolor="none")

    ax_h.axvline(metrics.var_95,         color=_RED,    lw=1.8, ls="--", label=f"VaR")
    ax_h.axvline(metrics.expected_value, color=_BLUE,   lw=1.8, label=f"Mean")
    ax_h.axvline(metrics.initial_value,  color=_TEXT_LO, lw=1.2, ls=":", label="Initial")

    ax_h.text(0.97, 0.96,
              f"P(loss)\n{metrics.prob_of_loss * 100:.1f}%",
              transform=ax_h.transAxes, ha="right", va="top",
              fontsize=9, color=_RED, fontweight="bold",
              bbox=dict(boxstyle="round,pad=0.3", fc=_BG_PANEL, ec=_RED, alpha=0.9))

    ax_h.set_title("Final Value Distribution", fontsize=10.5, fontweight="bold")
    ax_h.set_xlabel("Final Value (USD)", fontsize=9)
    ax_h.set_ylabel("Frequency", fontsize=9)
    _fmt_usd(ax_h, axis="x")
    ax_h.xaxis.set_major_locator(mticker.MaxNLocator(4))
    ax_h.legend(fontsize=7.5)
    ax_h.grid(True, axis="y", alpha=0.28)

    fname = f"{save_prefix}dashboard.png"
    plt.savefig(fname, dpi=150, bbox_inches="tight")
    print(f"  ✅  Saved: {fname}")
    plt.close()


# ──────────────────────────────────────────────────────────────────────────────
#  6. Entry Point
# ──────────────────────────────────────────────────────────────────────────────

def main() -> None:
    """
    Orchestrates the full analysis pipeline:
      get_data → calculate_returns → simulate_portfolio → calculate_metrics
      → print_metrics → plot_results
    """
    print("\n" + "═" * 54)
    print("  Monte Carlo Simulation — VTI Portfolio Risk")
    print("═" * 54 + "\n")

    # ── User-configurable parameters ──────────────────────────────────────
    initial_value   = INITIAL_VALUE     # USD
    time_horizon    = TIME_HORIZON      # trading days
    num_simulations = NUM_SIMULATIONS
    lookback_years  = LOOKBACK_YEARS

    # ── Pipeline ──────────────────────────────────────────────────────────
    prices  = get_data(ticker=TICKER, lookback_years=lookback_years)
    stats   = calculate_returns(prices)
    paths   = simulate_portfolio(
                  stats,
                  initial_value = initial_value,
                  time_horizon  = time_horizon,
                  num_sims      = num_simulations,
              )
    metrics = calculate_metrics(paths, initial_value)
    print_metrics(metrics, num_simulations, time_horizon)

    print("  📈  Generating visualisations …\n")
    plot_results(stats, paths, metrics, num_simulations, time_horizon)

    print("  ✅  Analysis complete.\n")


if __name__ == "__main__":
    main()
