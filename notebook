_RED      = "#f85149"
_YELLOW   = "#d29922"
_PURPLE   = "#bc8cff"


def _apply_dark_style() -> None:
    plt.rcParams.update({
        "figure.facecolor":  _BG_DARK,
        "axes.facecolor":    _BG_PANEL,
        "axes.edgecolor":    _BORDER,
        "axes.labelcolor":   _TEXT_MID,
        "axes.titlecolor":   _TEXT_HI,
        "text.color":        _TEXT_MID,
        "xtick.color":       _TEXT_LO,
        "ytick.color":       _TEXT_LO,
        "grid.color":        _BORDER,
        "grid.linewidth":    0.7,
        "font.family":       "sans-serif",
        "legend.facecolor":  _BG_PANEL,
        "legend.edgecolor":  _BORDER,
        "legend.fontsize":   8.5,
    })


def _fmt_usd(ax, axis: str = "y") -> None:
    """Apply dollar-sign formatting to an axis."""
    fmt = mticker.FuncFormatter(lambda x, _: f"${x:,.0f}")
    if axis == "y":
        ax.yaxis.set_major_formatter(fmt)
    else:
        ax.xaxis.set_major_formatter(fmt)


def plot_results(
    stats:   ReturnStats,
    paths:   np.ndarray,
    metrics: RiskMetrics,
    num_sims: int,
    time_horizon: int,
    save_prefix: str = "",
) -> None:
    """
    Generate three publication-quality charts:
      1. VTI historical price series
      2. Simulated portfolio paths (fan chart)
      3. Distribution of final portfolio values (histogram)

    Then assemble all three into a combined dashboard figure.
    """
    _apply_dark_style()

    _plot_historical(stats, save_prefix)
    _plot_paths(paths, metrics, num_sims, time_horizon, save_prefix)
    _plot_histogram(paths, metrics, num_sims, save_prefix)
    _plot_dashboard(stats, paths, metrics, num_sims, time_horizon, save_prefix)


# ── Chart 1: Historical VTI Price ────────────────────────────────────────────

def _plot_historical(stats: ReturnStats, save_prefix: str = "") -> None:
    """Plot the VTI historical adjusted closing price."""
    fig, ax = plt.subplots(figsize=(13, 4.5))

    prices = stats.prices
    ax.plot(prices.index, prices.values, color=_BLUE, linewidth=1.3, label=f"{TICKER} Adj. Close")

    # Rolling 50-day moving average
    ma50 = prices.rolling(50).mean()
    ax.plot(ma50.index, ma50.values, color=_YELLOW, linewidth=1.0,
            linestyle="--", alpha=0.85, label="50-Day MA")

    ax.fill_between(prices.index, prices.values, prices.min() * 0.95,
                    alpha=0.08, color=_BLUE)

    ax.set_title(f"VTI — Historical Adjusted Closing Price  "
                 f"({prices.index[0].date()} → {prices.index[-1].date()})",
                 fontsize=13, fontweight="bold")
    ax.set_xlabel("Date", fontsize=10)
    ax.set_ylabel("Adjusted Price (USD)", fontsize=10)
    _fmt_usd(ax)
    ax.legend()
    ax.grid(True, alpha=0.35)
    plt.tight_layout()

    fname = f"{save_prefix}vti_historical.png"
    plt.savefig(fname, dpi=150, bbox_inches="tight")
    print(f"  ✅  Saved: {fname}")
    plt.close()


# ── Chart 2: Simulated Paths ─────────────────────────────────────────────────

def _plot_paths(
    paths: np.ndarray,
    metrics: RiskMetrics,
    num_sims: int,
    time_horizon: int,
    save_prefix: str = "",
) -> None:
    """Fan chart of simulated portfolio trajectories."""
    fig, ax = plt.subplots(figsize=(13, 6))
    days = np.arange(time_horizon + 1)
    N    = paths.shape[1]

    # Draw a random sample of individual paths
    sample_idx = np.random.default_rng(0).choice(N, size=min(120, N), replace=False)
    for i in sample_idx:
        ax.plot(days, paths[:, i], linewidth=0.4, alpha=0.22, color=_BLUE)

    # Percentile bands
    p5  = np.percentile(paths, 5,  axis=1)
    p25 = np.percentile(paths, 25, axis=1)
    p50 = np.percentile(paths, 50, axis=1)
    p75 = np.percentile(paths, 75, axis=1)
    p95 = np.percentile(paths, 95, axis=1)

    ax.fill_between(days, p5,  p95, alpha=0.10, color=_BLUE,   label="5–95th Pct Band")
    ax.fill_between(days, p25, p75, alpha=0.18, color=_BLUE,   label="25–75th Pct Band")
    ax.plot(days, p5,  color=_RED,    lw=1.8, ls="--", label=f"5th Pct (VaR) — ${p5[-1]:,.0f}")
    ax.plot(days, p50, color=_GREEN,  lw=2.2, ls="-",  label=f"Median — ${p50[-1]:,.0f}")
    ax.plot(days, p95, color=_YELLOW, lw=1.8, ls="--", label=f"95th Pct — ${p95[-1]:,.0f}")
    ax.axhline(metrics.initial_value, color=_TEXT_LO, lw=1.2, ls=":",
               label=f"Initial — ${metrics.initial_value:,.0f}")

    ax.set_title(
        f"Monte Carlo Simulation — {num_sims:,} Paths over {time_horizon} Trading Days  "
        f"[calibrated on {TICKER}]",
        fontsize=12, fontweight="bold"
    )
    ax.set_xlabel("Trading Days Ahead", fontsize=10)
    ax.set_ylabel("Portfolio Value (USD)", fontsize=10)
    _fmt_usd(ax)
    ax.legend(loc="upper left", ncol=2)
    ax.grid(True, alpha=0.3)
    plt.tight_layout()

    fname = f"{save_prefix}simulation_paths.png"
    plt.savefig(fname, dpi=150, bbox_inches="tight")
    print(f"  ✅  Saved: {fname}")
    plt.close()


# ── Chart 3: Final Value Distribution ────────────────────────────────────────

def _plot_histogram(
    paths:   np.ndarray,
    metrics: RiskMetrics,
    num_sims: int,
    save_prefix: str = "",
) -> None:
    """Histogram of final portfolio values, colour-coded by gain/loss."""
    fig, ax = plt.subplots(figsize=(13, 5.5))
    final = paths[-1, :]

    n_bins = min(120, max(40, int(np.sqrt(len(final)))))
    counts, edges = np.histogram(final, bins=n_bins)

    for i, (lo, hi) in enumerate(zip(edges[:-1], edges[1:])):
        mid   = (lo + hi) / 2
        color = _RED if mid < metrics.initial_value else _GREEN
        ax.bar(lo, counts[i], width=(hi - lo), color=color, alpha=0.72, edgecolor="none")

    # Vertical reference lines
    ax.axvline(metrics.var_95,         color=_RED,    lw=2.0, ls="--",
               label=f"VaR 95%: ${metrics.var_95:,.0f}")
    ax.axvline(metrics.cvar_95,        color=_PURPLE, lw=1.6, ls=":",
               label=f"CVaR 95%: ${metrics.cvar_95:,.0f}")
    ax.axvline(metrics.expected_value, color=_BLUE,   lw=2.0, ls="-",
               label=f"Mean: ${metrics.expected_value:,.0f}")
    ax.axvline(metrics.median_value,   color=_YELLOW, lw=1.8, ls="-.",
               label=f"Median: ${metrics.median_value:,.0f}")
    ax.axvline(metrics.initial_value,  color=_TEXT_LO, lw=1.4, ls=":",
               label=f"Initial: ${metrics.initial_value:,.0f}")

    # Loss probability annotation
    ax.text(0.98, 0.95,
            f"P(loss) = {metrics.prob_of_loss * 100:.1f}%",
            transform=ax.transAxes, ha="right", va="top",
            fontsize=10.5, color=_RED, fontweight="bold",
            bbox=dict(boxstyle="round,pad=0.4", fc=_BG_PANEL, ec=_RED, alpha=0.9))

    ax.set_title(
        f"Distribution of Final Portfolio Values — {num_sims:,} Simulations  [{TICKER}]",
        fontsize=12, fontweight="bold"
    )
    ax.set_xlabel("Final Portfolio Value (USD)", fontsize=10)
    ax.set_ylabel("Frequency", fontsize=10)
    _fmt_usd(ax, axis="x")
    ax.legend(ncol=2)
    ax.grid(True, axis="y", alpha=0.3)
    plt.tight_layout()

    fname = f"{save_prefix}final_distribution.png"
    plt.savefig(fname, dpi=150, bbox_inches="tight")
    print(f"  ✅  Saved: {fname}")
    plt.close()


