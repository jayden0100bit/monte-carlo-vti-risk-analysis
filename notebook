"""
Monte Carlo Simulation of VTI Portfolio Risk
=============================================
Uses real historical price data from VTI (Vanguard Total Stock Market ETF)
to estimate return parameters, then simulates thousands of future portfolio
trajectories to quantify investment risk.

Dependencies: yfinance, numpy, pandas, matplotlib
Author: Portfolio Project
License: MIT
"""

import warnings
import sys
from dataclasses import dataclass, field
